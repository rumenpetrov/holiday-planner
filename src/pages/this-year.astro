---
import { changeLanguage, t } from "i18next";
import Layout from "@layouts/Layout.astro";
import Year from "@components/Year.astro";

changeLanguage("bg");

const year = new Date().getFullYear();
---

<script>
  import "@components/hp-typography";
</script>

<Layout
  title={`${t("GLOBAL.PROJECT_NAME")} - ${year} ${t("PAGES.THIS_YEAR.TITLE")}`}
>
  <h1 hidden>{year} - {t("PAGES.THIS_YEAR.TITLE")}</h1>

  <Year year={year}>
    <hp-typography disableMarginBottom slot="year" element="h2" appearance="h3">
      {year}
    </hp-typography>

    <hp-typography
      disableMarginBottom
      slot="title"
      element="h2"
      appearance="h1"
    >
      {t("PAGES.THIS_YEAR.TITLE")}
    </hp-typography>
  </Year>
</Layout>
